<launch>
    <arg name="world_name" default="$(find urdf02_gazebo)/worlds/hello.world" />
    <arg name="gui" default="true" />

    <!-- 将 Urdf 文件的内容加载到参数服务器 -->
    <param name="robot_description" command="$(find xacro)/xacro $(find urdf02_gazebo)/urdf/xacro/my_base_camera_laser.urdf.xacro" />

    <!-- 启动 gazebo -->
    <include file="$(find gazebo_ros)/launch/empty_world.launch" >
        <arg name="world_name" value="$(arg world_name)" />
        <arg name="gui" value="$(arg gui)" />
    </include>

    <!-- 在 gazebo 中显示机器人模型 -->
    <node pkg="gazebo_ros" type="spawn_model" name="model" args="-urdf -model mycar -param robot_description -z 0.05"  />
</launch>
